<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/adviceHistoryRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/smart_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/adviceHistoryBackButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="12dp"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/smart_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_header_panel"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/adviceHistoryTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/advice_history"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adviceHistoryMonthText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/smart_accent_soft"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Review previous advice generated for this month's budget."
                android:textColor="@color/white"
                android:textSize="15sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/smart_surface"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/smart_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/adviceHistoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
